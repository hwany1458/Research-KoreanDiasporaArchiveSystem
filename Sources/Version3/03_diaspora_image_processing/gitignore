# -------------------------------------------------------------
# 모델 가중치 (대용량, 별도 다운로드)
# -------------------------------------------------------------
weights/*.pth
weights/*.pt
weights/*.bin
weights/*.safetensors
# 단 weights/README.md 는 추적
!weights/README.md

# -------------------------------------------------------------
# 입출력 데이터 (개인정보 · 저작권 이슈)
# -------------------------------------------------------------
data/input/*
data/output/*
# 폴더 자체는 유지하기 위한 keepfile
!data/input/.gitkeep
!data/output/.gitkeep

# 단계별 중간 결과 폴더
*_stages/

